{
  "name": "sc-kerat-mud-client",
  "private": true,
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cytoscape": "^3.33.1",
    "postgres": "^3.4.7",
    "zod": "^4.3.6"
  },
  "scripts": {
    "dev": "bun run build:client && bun --watch src/server.ts",
    "start": "bun run build:client && bun run src/server.ts",
    "build:client": "bun run scripts/build-client.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:client && bun run typecheck",
    "test": "bun test",
    "smoke": "bun run build:client && bun run scripts/smoke-test.ts",
    "gear": "bun run scripts/gear-advisor.ts"
  },
  "devDependencies": {
    "@ladybugdb/core": "^0.15.2",
    "bun-types": "latest",
    "gitnexus": "^1.4.9",
    "typescript": "^5.9.2"
  },
  "trustedDependencies": [
    "@ladybugdb/core",
    "onnxruntime-node",
    "protobufjs",
    "tree-sitter-c",
    "tree-sitter-c-sharp",
    "tree-sitter-cpp",
    "tree-sitter-dart",
    "tree-sitter-go",
    "tree-sitter-java",
    "tree-sitter-javascript",
    "tree-sitter-php",
    "tree-sitter-python",
    "tree-sitter-ruby",
    "tree-sitter-rust",
    "tree-sitter-swift"
  ]
}
