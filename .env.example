HOST=0.0.0.0
PORT=3000

# Auto-connect on every app startup using the built-in startup script defaults.
MUD_AUTO_CONNECT=true

# Default MUD target shown in the browser UI and used by the startup script.
MUD_HOST=bylins.su
MUD_PORT=7000
MUD_TLS=false

# Separate multiple commands with ;; or newlines.
MUD_STARTUP_COMMANDS=5;;воинмир;;respect1
MUD_COMMAND_DELAY_MS=150
MUD_LINE_ENDING=crlf

# Required PostgreSQL for the automapper. The server will refuse to start without it.
DATABASE_URL=postgres://bylins:bylins@localhost:5432/bylins_bot

# Optional proxy list for wiki.bylins.su requests (comma-separated, format: host:port:user:pass).
# WIKI_PROXIES=45.81.77.28:8000:user:pass,45.81.77.167:8000:user:pass

# Reverse proxy deployment settings.
DOMAIN=sc.kerat.ru
BASIC_AUTH_USERNAME=admin
# Generate with: caddy hash-password --plaintext 'your-password'
BASIC_AUTH_PASSWORD_HASH=$2a$14$replace_me_with_a_real_hash

# Telegram notifications for bazaar watched items.
# Get token from @BotFather, chat_id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
